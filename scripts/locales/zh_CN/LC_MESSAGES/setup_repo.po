# Simplified Chinese catalog for resume-cicd-lab wizards.
# Voice rules (see memory/project-resume-cicd-lab-wizard-i18n-design.md):
#   - 你 (not 您) — Ant Design dev-tool convention
#   - half-width space between CJK and Latin/digits
#   - declarative, not promotional; short sentences
#   - 正在... / 已完成 for progress transitions
#   - translate infra nouns (部署/容器/回滚), keep git verbs English
msgid ""
msgstr ""
"Project-Id-Version: setup_repo 0.1\n"
"POT-Creation-Date: 2026-04-22 12:00+0000\n"
"PO-Revision-Date: 2026-04-22 12:00+0000\n"
"Language: zh_CN\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

# ----------------------------------------------------------------------
# First-run locale picker
# ----------------------------------------------------------------------

msgid "UI language"
msgstr "UI 语言"

msgid "Auto (detected: {locale})"
msgstr "自动 (检测到: {locale})"

msgid "Commands and flags stay English in every locale."
msgstr "命令和 flag 在任何语言下都保持英文。"

msgid "Change anytime: ./scripts/setup_repo.py configure --locale <lang>"
msgstr "任何时候都能修改: ./scripts/setup_repo.py configure --locale <lang>"

# ----------------------------------------------------------------------
# validate-tools
# ----------------------------------------------------------------------

msgid "Tool status"
msgstr "工具状态"

msgid "Tool"
msgstr "工具"

msgid "Available"
msgstr "可用"

msgid "Version"
msgstr "版本"

msgid "Authenticated"
msgstr "已认证"

msgid "Toolchain ready"
msgstr "工具链准备好了"

msgid "Next: Lab {n} — {title}"
msgstr "接下来: Lab {n} — {title}"

msgid "First command:"
msgstr "第一条命令:"

msgid "{tool} not on your PATH"
msgstr "{tool} 不在 PATH 中"

msgid "{tool} {v} is below the minimum {floor}"
msgstr "{tool} {v} 低于最低版本 {floor}"

# ----------------------------------------------------------------------
# apply flow
# ----------------------------------------------------------------------

msgid "Grab a coffee — we'll tell you when it's done."
msgstr "去喝杯咖啡吧 — 完成后会通知你。"

msgid "Estimated wait"
msgstr "预计等待时间"

msgid "Your first AWS infrastructure is alive"
msgstr "你的第一套 AWS 基础设施正在运行"

msgid "Running stacks ({n}):"
msgstr "正在运行的 stack ({n}):"

msgid "Daily cost: ${x}"
msgstr "每日成本: ${x}"

# ----------------------------------------------------------------------
# typed-scope destroy
# ----------------------------------------------------------------------

msgid "This is destructive. Type the exact scope below to confirm:"
msgstr "这是破坏性操作。请逐字输入下面的 scope 来确认:"

msgid "Scope confirmed — proceeding."
msgstr "scope 已确认 — 开始执行。"

# ----------------------------------------------------------------------
# destroy success
# ----------------------------------------------------------------------

msgid "Environment peacefully gone"
msgstr "环境已安全清理"

msgid "Removed: {n} stacks · {o} S3 objects · {i} ECR images"
msgstr "已删除: {n} 个 stack · {o} 个 S3 对象 · {i} 个 ECR 镜像"

msgid "Cost stopped: ${x}/day"
msgstr "已停止成本: ${x}/day"

msgid "To come back later:"
msgstr "需要再来一次:"

# ----------------------------------------------------------------------
# claim + promotion
# ----------------------------------------------------------------------

msgid "Lab {n} claim PR opened"
msgstr "Lab {n} claim PR 已开"

msgid "Auto-merge when CI is green:"
msgstr "CI 变绿后自动合并:"

msgid "{env} promotion ready"
msgstr "{env} promotion 准备就绪"

# ----------------------------------------------------------------------
# common errors
# ----------------------------------------------------------------------

msgid "Not inside a git repository."
msgstr "请在 git 仓库内运行。"

# ----------------------------------------------------------------------
# Questionary constants (monkey-patched in wizard.i18n)
# ----------------------------------------------------------------------

msgid "Yes"
msgstr "是"

msgid "No"
msgstr "否"

msgid "(Y/n)"
msgstr "(Y/n)"

msgid "(y/N)"
msgstr "(y/N)"

msgid "Cancelled by user."
msgstr "已取消。"

msgid "Invalid input"
msgstr "输入无效"

msgid "(Use arrow keys)"
msgstr "(使用方向键选择)"

msgid "(Use arrow keys + space to select)"
msgstr "(使用方向键 + 空格键选择)"
