{
  "project": {
    "slug": "resume-cicd-lab",
    "displayName": "Resume CI/CD Lab",
    "description": "Hands-on CI/CD teaching lab that ships a resume."
  },
  "github": {
    "owner": "shiicho",
    "repo": "resume-cicd-lab-goushuukai-template",
    "visibility": "public",
    "createRepo": true,
    "topics": [
      "cicd-lab",
      "learning-lab",
      "resume",
      "react",
      "cloudformation",
      "ecs",
      "s3"
    ]
  },
  "aws": {
    "region": "ap-northeast-1",
    "stackPrefix": "resume-cicd-lab",
    "resourceProjectName": "resume",
    "resourceIdentifier": "cicd-lab",
    "resourceShortIdentifier": "cl",
    "existingGitHubOidcProviderArn": ""
  },
  "safety": {
    "dailyCap": 10,
    "email": ""
  },
  "release": {
    "bootstrapVersion": "0.1.0",
    "bootstrapGitSha": "bootstrap"
  },
  "staticSite": {
    "priceClass": "PriceClass_200",
    "defaultRootObject": "index.html"
  },
  "ecs": {
    "cpu": "256",
    "memory": "512",
    "containerPort": 8080,
    "healthCheckPath": "/",
    "bootstrapImageUri": "public.ecr.aws/nginx/nginx-unprivileged:stable-alpine"
  },
  "environments": {
    "development": {
      "vpcCidr": "10.40.0.0/16",
      "publicSubnet1Cidr": "10.40.0.0/24",
      "publicSubnet2Cidr": "10.40.1.0/24",
      "desiredCount": 1
    },
    "staging": {
      "vpcCidr": "10.50.0.0/16",
      "publicSubnet1Cidr": "10.50.0.0/24",
      "publicSubnet2Cidr": "10.50.1.0/24",
      "desiredCount": 1
    },
    "production": {
      "vpcCidr": "10.60.0.0/16",
      "publicSubnet1Cidr": "10.60.0.0/24",
      "publicSubnet2Cidr": "10.60.1.0/24",
      "desiredCount": 2
    }
  }
}
